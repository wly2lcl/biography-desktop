{
  "productName": "BiographyDesktop",
  "version": "0.1.0",
  "identifier": "com.biography.generator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:8080",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "传记生成器",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "center": true,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://api.deepseek.com https://api.openai.com; font-src 'self' data:; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "dmg", "app", "nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
