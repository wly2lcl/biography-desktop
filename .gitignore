# Dependencies
node_modules/
coverage/

# Build outputs
dist/

# Tauri build outputs
src-tauri/target/
# Platform-specific schemas are regenerated by Tauri on each host.
src-tauri/gen/schemas/*-schema.json

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Environment
.env
.env.local

# GitHub token (never commit)
.github/GH_TOKEN

# Python
__pycache__/
*.pyc
*.pyo

# Tauri build outputs
src-tauri/target/

# User custom locale overrides
src/i18n/locales/*.json
!src/i18n/locales/zh-CN.json
