{
  "name": "biography-desktop",
  "version": "0.1.0",
  "description": "LLM-driven interactive biographical narrative desktop app",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prebuild:icons": "bash scripts/verify-icons.sh",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "build:all": "npm run tauri build && echo '✓ Build complete. Output in src-tauri/target/release/bundle/' && ls src-tauri/target/release/bundle/*/"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "dompurify": "^3.0.0",
    "marked": "^12.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.13",
    "@tauri-apps/cli": "^2.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "happy-dom": "^20.9.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.8"
  }
}
